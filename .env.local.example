# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Anthropic (Claude AI) — Devocionais gerados por IA
ANTHROPIC_API_KEY=sk-ant-...

# Resend — Email (aprovação, recuperação de senha)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@selah.app

# Web Push Notifications (gerar com: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...

# WhatsApp Business API (Meta)
WHATSAPP_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_VERIFY_TOKEN=selah-webhook-verify

# Google Calendar API
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_CALENDAR_ID=...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=edson.barroso@gmail.com
