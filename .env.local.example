# =============================================================================
# SELAH APP — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# =============================================================================

# ── Supabase (OBRIGATÓRIO) ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# ── AI — Anthropic (OBRIGATÓRIO) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AI — OpenAI (OBRIGATÓRIO) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1  # opcional: endpoint customizado

# ── Email — Resend (opcional) ─────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@selah.app

# ── Web Push — VAPID (opcional) ───────────────────────────────────────────────
# Gerar com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...

# ── Google Calendar API (opcional) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_CALENDAR_ID=...
GOOGLE_REFRESH_TOKEN=...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron (opcional) ───────────────────────────────────────────────────────────
CRON_SECRET=...
# NEXT_PUBLIC_CRON_SECRET=...  # apenas se o client precisar verificar

# ── Admin seed (opcional) ─────────────────────────────────────────────────────
# Email do primeiro admin — usado apenas no seed inicial do banco.
# Prefer definir role=admin diretamente no Supabase Dashboard.
ADMIN_EMAIL=admin@selah.app
